# QGI-DEMO — additional env vars for qwork-underwriting
#
# APPEND these to qwork's `.env.local` (NOT the committed `.env`).
# The leading VITE_ prefix exposes them to the browser bundle.

# URL where QGI Life-Signals-IQ is running. Dev default assumes you run
# `qgi-life-signals-iq-web --host 127.0.0.1 --port 8765` on the same host
# as `vite dev`.
VITE_LSIQ_URL=http://127.0.0.1:8765

# Bearer token matching LSIQ_AUTH_TOKEN in the Python service.
# Leave blank to run LSIQ without auth (dev only).
VITE_LSIQ_TOKEN=demo-dev-token-123

# Feature flag for the new Social Verification tab. Setting this to 'true'
# exposes the tab on LoanDetail; anything else hides it entirely.
VITE_QGI_DEMO_SOCIAL_VERIFY=true

# Display-only client label rendered in the tab header. Keep neutral until
# the client brand is finalized; swap to the real name (e.g. "Supreme")
# before the pitch.
VITE_QGI_DEMO_CLIENT_LABEL=QGI-DEMO
