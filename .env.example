# QGI Life-Signals-IQ — runtime configuration
#
# All values are optional. Copy to `.env` and fill in what you need.
# No secrets are required to run the standalone UI; these only matter
# when LSIQ is embedded as a microservice behind a product like
# qwork-underwriting.

# -----------------------------------------------------------------------------
# HTTP bind
# -----------------------------------------------------------------------------
LSIQ_HOST=127.0.0.1
LSIQ_PORT=8765

# -----------------------------------------------------------------------------
# CORS (required when a browser SPA calls the API cross-origin)
# -----------------------------------------------------------------------------
# Comma-separated list of exact origins (preferred).
LSIQ_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional regex (e.g. match every *.vercel.app preview). Use instead of,
# or in addition to, LSIQ_CORS_ORIGINS.
# LSIQ_CORS_ORIGIN_REGEX=^https://qwork-.*\.vercel\.app$

# -----------------------------------------------------------------------------
# Bearer auth
# -----------------------------------------------------------------------------
# When set, every /api/* call (except /api/health, /api/meta) requires
# `Authorization: Bearer <token>`. The same token goes into the qwork
# frontend as VITE_LSIQ_TOKEN.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# LSIQ_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# QSS provider (phase 2)
# -----------------------------------------------------------------------------
# Selects the QSSProvider binding used by /api/qss/*. Default is 'stub' — a
# deterministic zero-dependency implementation suitable for demos. Phase 4
# will ship 'http' (remote QSS service) and 'quantum' (in-process binding).
QSS_PROVIDER=stub
# QSS_HTTP_URL=
# QSS_HTTP_TOKEN=
